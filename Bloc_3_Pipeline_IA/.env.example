# ── PostgreSQL ──────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fraud_detection
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── API temps réel ───────────────────────────────────────────────────────────
API_BASE_URL=https://sdacelo-real-time-fraud-detection.hf.space
POLL_INTERVAL_S=60

# ── Modèle ML ────────────────────────────────────────────────────────────────
MODEL_PATH=model/fraud_model.pkl
FRAUD_THRESHOLD=0.5

# ── Email (SMTP Gmail) ────────────────────────────────────────────────────────
# Pour Gmail : activer "Mot de passe d'application" dans les paramètres de compte
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASSWORD=votre_app_password
ALERT_RECIPIENTS=destinataire1@email.com,destinataire2@email.com

# ── Rapport quotidien (heure UTC) ─────────────────────────────────────────────
DAILY_REPORT_HOUR=8
DAILY_REPORT_MINUTE=0
